&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>./socket/opensock.c
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>./sunrpc/openchild.c
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>./sysdeps/mach/hurd/open.c
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>./sysdeps/mach/hurd/open64.c
