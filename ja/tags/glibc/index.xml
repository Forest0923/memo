&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>./sysdeps/unix/sysv/linux/open_by_handle_at.c
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>./sysdeps/unix/sysv/linux/open_nocancel.c
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>./sysdeps/unix/sysv/linux/openat.c
