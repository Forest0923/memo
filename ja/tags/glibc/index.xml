&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> &lt;span style="color:#447fcf">movq&lt;/span> &lt;span style="color:#40ffff">%rdx&lt;/span>, &lt;span style="color:#40ffff">%rsi&lt;/span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> &lt;span style="color:#447fcf">movq&lt;/span> &lt;span style="color:#40ffff">%rcx&lt;/span>, &lt;span style="color:#40ffff">%rdx&lt;/span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> &lt;span style="color:#447fcf">movq&lt;/span> &lt;span style="color:#40ffff">%r8&lt;/span>, &lt;span style="color:#40ffff">%r10&lt;/span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> &lt;span style="color:#447fcf">movq&lt;/span> &lt;span style="color:#40ffff">%r9&lt;/span>, &lt;span style="color:#40ffff">%r8&lt;/span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> &lt;span style="color:#447fcf">movq&lt;/span> &lt;span style="color:#3677a9">8&lt;/span>(&lt;span style="color:#40ffff">%rsp&lt;/span>),&lt;span style="color:#40ffff">%r9&lt;/span> &lt;span style="color:#999;font-style:italic">/* arg6 is on the stack. */&lt;/span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> &lt;span style="color:#447fcf">syscall&lt;/span> &lt;span style="color:#999;font-style:italic">/* Do the system call. */&lt;/span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> &lt;span style="color:#447fcf">cmpq&lt;/span> &lt;span style="color:#40ffff">$-4095&lt;/span>, &lt;span style="color:#40ffff">%rax&lt;/span> &lt;span style="color:#999;font-style:italic">/* Check %rax for error. */&lt;/span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> &lt;span style="color:#447fcf">jae&lt;/span> &lt;span style="color:#40ffff">SYSCALL_ERROR_LABEL&lt;/span> &lt;span style="color:#999;font-style:italic">/* Jump to error handler if error. */&lt;/span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> &lt;span style="color:#447fcf">ret&lt;/span> &lt;span style="color:#999;font-style:italic">/* Return to caller. */&lt;/span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#447fcf">PSEUDO_END&lt;/span> (&lt;span style="color:#40ffff">syscall&lt;/span>)
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;ul>
